          <elementProp name="messageEnvoiMessage" elementType="Argument">
            <stringProp name="Argument.name">messageEnvoiMessage</stringProp>
            <stringProp name="Argument.value">${surnom} &gt; ${message}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
        </collectionProp>
